{
  "name": "@openawa/cli",
  "version": "0.0.0-semantic-release",
  "private": false,
  "homepage": "https://github.com/openawa/openawa",
  "bugs": {
    "url": "https://github.com/openawa/openawa/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openawa/openawa"
  },
  "bin": {
    "openawa": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "check": "npm-run-all --parallel typecheck lint format:check",
    "dev": "tsx src/cli.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --deny-warnings .",
    "release": "release-it",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:e2e": "pnpm run build && vitest run --project e2e",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@chipkey/cli": "^0.5.1",
    "@clack/prompts": "^1.1.0",
    "incur": "^0.2.2",
    "porto": "^0.2.37",
    "viem": "^2.47.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^22.13.4",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "node-pty": "^1.2.0-beta.11",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "playwright": "^1.58.2",
    "release-it": "^19.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}": [
      "oxlint --fix --deny-warnings",
      "oxfmt"
    ],
    "**/*.{json,jsonc,md,yaml,yml}": "oxfmt"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
